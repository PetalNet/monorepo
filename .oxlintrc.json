{
	"$schema": "./node_modules/oxlint/configuration_schema.json",
	"plugins": ["typescript", "unicorn", "import", "node", "promise"],
	"categories": {
		"correctness": "error",
		"suspicious": "warn",
		"perf": "warn",
		"style": "off",
		"pedantic": "off"
	},
	"ignorePatterns": [
		"**/dist/**",
		"**/build/**",
		"**/.svelte-kit/**",
		"**/node_modules/**",
		"**/coverage/**"
	]
}
