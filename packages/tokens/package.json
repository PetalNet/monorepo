{
	"name": "@petalnet/tokens",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		},
		"./css": "./dist/tokens.css",
		"./tailwind": {
			"types": "./dist/tailwind.preset.d.ts",
			"default": "./dist/tailwind.preset.js"
		},
		"./daisyui": "./dist/daisyui.css",
		"./daisyui/paper": {
			"types": "./dist/daisyui.paper.d.ts",
			"default": "./dist/daisyui.paper.js"
		},
		"./daisyui/ink": {
			"types": "./dist/daisyui.ink.d.ts",
			"default": "./dist/daisyui.ink.js"
		}
	},
	"scripts": {
		"build": "node tools/build.mts",
		"test": "node --test tools/*.test.mts",
		"typecheck": "tsc -b"
	},
	"devDependencies": {
		"@petalnet/tsconfig": "workspace:*",
		"@types/node": "catalog:types",
		"style-dictionary": "catalog:dev",
		"typescript": "catalog:dev"
	}
}
