{
	"font": {
		"family": {
			"$type": "fontFamily",
			"sans": {
				"$value": [
					"Inter",
					"system-ui",
					"-apple-system",
					"BlinkMacSystemFont",
					"Segoe UI",
					"Roboto",
					"sans-serif"
				]
			},
			"serif": { "$value": ["Fraunces", "ui-serif", "Georgia", "serif"] },
			"mono": {
				"$value": [
					"JetBrains Mono",
					"ui-monospace",
					"SFMono-Regular",
					"Menlo",
					"Consolas",
					"monospace"
				]
			}
		},
		"size": {
			"$type": "dimension",
			"xs": { "$value": "0.75rem" },
			"sm": { "$value": "0.875rem" },
			"base": { "$value": "1rem" },
			"lg": { "$value": "1.125rem" },
			"xl": { "$value": "1.25rem" },
			"2xl": { "$value": "1.5rem" },
			"3xl": { "$value": "1.875rem" },
			"4xl": { "$value": "2.25rem" }
		},
		"weight": {
			"$type": "fontWeight",
			"regular": { "$value": "400" },
			"medium": { "$value": "500" },
			"semibold": { "$value": "600" },
			"bold": { "$value": "700" }
		}
	}
}
