{
	"color": {
		"$type": "color",
		"$description": "Design-system primitive palette — the warm paper/ink scale and the burnt-sienna 'petal' accent. Mirrors apps/design/site styles.css :root token block (DESIGN.md §2). These are RAW values; the semantic layer (light.json/dark.json) maps them to roles.",

		"paper": {
			"$description": "Light-theme warm paper/ink ramp.",
			"white": { "$value": "#ffffff" },
			"surface": { "$value": "#f6f5f3" },
			"elev": { "$value": "#fbfaf9" },
			"rule": { "$value": "#ececea" },
			"rule-strong": { "$value": "#d9d7d3" },
			"ink": { "$value": "#161412" },
			"ink-mute": { "$value": "#645f59" },
			"ink-soft": { "$value": "#97928b" }
		},

		"ink": {
			"$description": "Dark-theme warm ink ramp.",
			"bg": { "$value": "#0d0c0b" },
			"surface": { "$value": "#161413" },
			"elev": { "$value": "#1d1b19" },
			"rule": { "$value": "#262321" },
			"rule-strong": { "$value": "#36322f" },
			"text": { "$value": "#ece8e3" },
			"text-mute": { "$value": "#9a938b" },
			"text-soft": { "$value": "#645e57" }
		},

		"petal": {
			"$description": "THE accent — burnt sienna. Theme-aware pair: paper = deepened (AA on white), ink = base. Hover/active derived via color-mix in CSS at runtime; literal here as fallbacks.",
			"paper": { "$value": "#bc5638" },
			"ink": { "$value": "#e2725b" },
			"hover": { "$value": "#a14a30" },
			"active": { "$value": "#8b3f29" }
		},

		"status": {
			"$description": "Semantic status hues (paper-tuned).",
			"success": { "$value": "#2f8f5b" },
			"warning": { "$value": "#c77d11" },
			"danger": { "$value": "#c5374b" }
		}
	}
}
