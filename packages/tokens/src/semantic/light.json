{
	"$description": "Light theme semantic tokens. References primitive tokens; DaisyUI's @plugin theme consumes the CSS-var output.",
	"semantic": {
		"color": {
			"$type": "color",
			"bg": { "$value": "{color.gray.50}" },
			"surface": { "$value": "#ffffff" },
			"surface-2": { "$value": "{color.gray.100}" },
			"fg": { "$value": "{color.gray.900}" },
			"fg-dim": { "$value": "{color.gray.600}" },
			"border": { "$value": "{color.gray.200}" },
			"accent": { "$value": "{color.blue.500}" },
			"ok": { "$value": "{color.green.500}" },
			"warn": { "$value": "{color.amber.500}" },
			"err": { "$value": "{color.red.500}" }
		}
	}
}
