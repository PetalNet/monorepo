{
	"$schema": "https://docs.renovatebot.com/renovate-schema.json",
	"extends": [
		"config:best-practices",
		"preview:dockerCompose",
		"preview:dockerVersions",
		":automergeDigest",
		":automergeLinters",
		":automergePatch",
		":disableRateLimiting",
		":pinAllExceptPeerDependencies",
		":preserveSemverRanges",
		":semanticCommits"
	],
	"postUpdateOptions": ["pnpmDedupe"],
	"minimumReleaseAge": "7 days",
	"labels": ["dependencies"],
	"automergeStrategy": "squash",
	"customManagers": [
		{
			"customType": "regex",
			"description": "Keep the CI-installed vp (setup-vp version) in sync with the vite-plus catalog pin",
			"managerFilePatterns": ["/^\\.github/workflows/[^/]+\\.ya?ml$/"],
			"matchStrings": [
				"# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)\\s+version: \"(?<currentValue>[^\"]+)\""
			]
		}
	],
	"packageRules": [
		{
			"matchPackageNames": ["/eslint/"],
			"groupName": "eslint"
		},
		{
			"matchPackageNames": ["/^vite-plus/", "oxlint", "/^@oxc-/", "/^oxc-/"],
			"groupName": "voidzero"
		},
		{
			"matchPackageNames": ["/^tailwindcss/", "/^@tailwindcss//", "daisyui"],
			"groupName": "tailwind"
		}
	]
}
