# Point home-server configuration. Copy to `.env` and fill in.
#   cp .env.example .env
# The compose stack derives DATABASE_URL from the values below, so you only set
# what's here. The server refuses to boot on a missing/weak JWT_SECRET or a
# missing DOMAIN — an unbootable server beats a silently insecure one.

# --- Required -------------------------------------------------------------

# Public hostname of this home-server. It is the `@domain` suffix of every local
# user id and what peers federate with. Bare host — no scheme, port, or path.
DOMAIN=point.example.org

# Email for the Let's Encrypt account Traefik registers (cert-expiry notices).
ACME_EMAIL=you@example.org

# Token-signing secret. MUST be 32+ chars or the server won't boot. Generate:
#   openssl rand -hex 32
JWT_SECRET=

# Postgres password. Generate: openssl rand -hex 24
POSTGRES_PASSWORD=

# --- Optional (sensible defaults) ----------------------------------------

# Published server image tag. Pin to a release (e.g. 1.0.0) in production;
# `latest` follows the newest tagged release.
#POINT_VERSION=latest

# Allow anyone to self-register. Default false — invite-only. Set true for an
# open instance.
#OPEN_REGISTRATION=false

# Postgres user / db name (defaults: point / point).
#POSTGRES_USER=point
#POSTGRES_DB=point

# Public https base advertised in /.well-known/point. Defaults to https://$DOMAIN
# — override only if peers reach you at a different URL.
#PUBLIC_URL=https://point.example.org

# Error reporting (Glitchtip/Sentry DSN). Empty = disabled.
#GLITCHTIP_DSN=

# --- OIDC single sign-on (optional) --------------------------------------
# Uncomment all four to delegate login to an OIDC provider (local accounts
# keep working regardless).
#OIDC_ENABLED=true
#OIDC_ISSUER=https://auth.example.org
#OIDC_CLIENT_ID=
#OIDC_CLIENT_SECRET=
