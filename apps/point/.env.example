# Point server configuration. Copy to `.env` and fill in.

# Postgres connection string. Matches the docker-compose `postgres` service.
DATABASE_URL=postgres://point:point@postgres:5432/point

# Address the server binds. Plain HTTP; Traefik terminates TLS in front.
LISTEN=0.0.0.0:8330

# REQUIRED. Signing secret for tokens. Generate 32+ random chars, e.g.:
#   openssl rand -hex 32
# The server refuses to boot if this is missing or shorter than 32 chars.
JWT_SECRET=

# Public domain this home-server federates under (e.g. point.example.com).
DOMAIN=

# Whether strangers can self-register on this server. Default closed.
OPEN_REGISTRATION=false

# Optional: Sentry-compatible DSN for error reporting (Glitchtip). Empty = off.
GLITCHTIP_DSN=

# Optional OIDC single sign-on (local accounts always work regardless).
# OIDC_ENABLED=true requires the other three values.
OIDC_ENABLED=false
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
# Public base URL of this server (for the OIDC redirect), e.g. https://point.example.org
PUBLIC_URL=
