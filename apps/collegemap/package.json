{
	"name": "@petalnet/collegemap",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"build": "vite build",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:push": "drizzle-kit push",
		"db:studio": "drizzle-kit studio",
		"dev": "vite dev",
		"prepare": "svelte-kit sync || echo ''",
		"preview": "vite preview"
	},
	"devDependencies": {
		"@sveltejs/adapter-node": "catalog:dev",
		"@sveltejs/kit": "catalog:dev",
		"@sveltejs/vite-plugin-svelte": "catalog:dev",
		"@tailwindcss/vite": "catalog:dev",
		"@types/leaflet.heat": "catalog:types",
		"@types/leaflet.markercluster": "catalog:types",
		"@types/node": "catalog:types",
		"svelte": "catalog:dev",
		"svelte-check": "catalog:dev",
		"tailwindcss": "catalog:dev",
		"typescript": "catalog:dev",
		"vite": "catalog:dev"
	},
	"dependencies": {
		"@libsql/client": "catalog:prod",
		"@types/leaflet": "catalog:types",
		"drizzle-kit": "catalog:dev",
		"drizzle-orm": "catalog:prod",
		"leaflet": "catalog:prod",
		"leaflet-image": "catalog:prod",
		"leaflet.heat": "catalog:prod",
		"leaflet.markercluster": "catalog:prod"
	}
}
