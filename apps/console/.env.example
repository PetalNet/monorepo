# Lab Console frontend env. Copy to .env for local dev.

# Backend contract surface (console-api). LAN-only until the doorman gate lands.
PUBLIC_CONSOLE_API_BASE=https://console-api.petalcat.dev/api/v1
DATABASE_URL=postgresql://console_auth:replace-me@postgres/console
BETTER_AUTH_URL=https://console.petalcat.dev
BETTER_AUTH_SECRET=
BETTER_AUTH_COOKIE_DOMAIN=.petalcat.dev
AUTHENTIK_OIDC_ISSUER=https://auth.petalcat.dev/application/o/console/
AUTHENTIK_OIDC_CLIENT_ID=
AUTHENTIK_OIDC_CLIENT_SECRET=

# Data mode: 'mock' serves contract-shaped fixtures (no backend needed);
# 'live' talks to PUBLIC_CONSOLE_API_BASE. Defaults to mock until the API is up.
PUBLIC_CONSOLE_DATA_MODE=mock

# Error reporting (Glitchtip/Sentry-compatible DSN). Empty = disabled.
PUBLIC_GLITCHTIP_DSN=
