{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "https://petalcat.dev/schemas/console/work-settlement.schema.json",
	"title": "Work settlement snapshot (GET /work/settlement)",
	"description": "Caller-scoped time lenses over tracker-owned closed tasks. No entity is copied or mutated: task:<id> remains the stable Library identity.",
	"type": "object",
	"properties": {
		"schema_version": { "const": 1 },
		"observed_at": { "type": "string", "format": "date-time" },
		"settle_window_s": { "const": 86400 },
		"settled_this_week": { "type": "integer", "minimum": 0 },
		"invalid_timestamp_count": { "type": "integer", "minimum": 0 },
		"settling": {
			"type": "array",
			"items": {
				"allOf": [
					{ "$ref": "entities/task.schema.json" },
					{
						"type": "object",
						"properties": { "settles_at": { "type": "string", "format": "date-time" } },
						"required": ["settles_at"]
					}
				]
			}
		},
		"history": {
			"type": "array",
			"items": {
				"allOf": [
					{ "$ref": "entities/task.schema.json" },
					{
						"type": "object",
						"properties": { "settles_at": { "type": "string", "format": "date-time" } },
						"required": ["settles_at"]
					}
				]
			}
		}
	},
	"required": [
		"schema_version",
		"observed_at",
		"settle_window_s",
		"settled_this_week",
		"invalid_timestamp_count",
		"settling",
		"history"
	],
	"additionalProperties": false
}
