{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "https://petalcat.dev/schemas/console/cost-comparison-result.schema.json",
	"title": "Cost pairwise comparison result",
	"type": "object",
	"required": [
		"schema_version",
		"dimension",
		"left",
		"right",
		"metrics",
		"query_ref",
		"pricing_query_ref",
		"observed_at",
		"receipt"
	],
	"additionalProperties": false,
	"properties": {
		"schema_version": { "const": 1 },
		"dimension": { "enum": ["agent", "model", "project"] },
		"left": { "$ref": "#/$defs/side" },
		"right": { "$ref": "#/$defs/side" },
		"metrics": {
			"type": "array",
			"items": { "$ref": "#/$defs/metric" }
		},
		"query_ref": { "type": "string" },
		"pricing_query_ref": { "type": "string" },
		"observed_at": { "type": "string", "format": "date-time" },
		"receipt": { "$ref": "#/$defs/receipt" }
	},
	"$defs": {
		"side": {
			"type": "object",
			"required": [
				"value",
				"cost",
				"tokens",
				"sessions",
				"cost_per_session",
				"tokens_per_session",
				"input_tokens",
				"output_tokens",
				"cache_creation_tokens",
				"cache_read_tokens"
			],
			"additionalProperties": false,
			"properties": {
				"value": { "type": "string" },
				"cost": { "type": "number" },
				"tokens": { "type": "number" },
				"sessions": { "type": "integer", "minimum": 0 },
				"cost_per_session": { "type": "number" },
				"tokens_per_session": { "type": "number" },
				"input_tokens": { "type": "number" },
				"output_tokens": { "type": "number" },
				"cache_creation_tokens": { "type": "number" },
				"cache_read_tokens": { "type": "number" }
			}
		},
		"metric": {
			"type": "object",
			"required": ["key", "left", "right", "delta", "ratio"],
			"additionalProperties": false,
			"properties": {
				"key": {
					"enum": [
						"cost",
						"tokens",
						"sessions",
						"cost_per_session",
						"tokens_per_session",
						"input_tokens",
						"output_tokens",
						"cache_creation_tokens",
						"cache_read_tokens"
					]
				},
				"left": { "type": "number" },
				"right": { "type": "number" },
				"delta": { "type": "number" },
				"ratio": { "type": ["number", "null"] }
			}
		},
		"receipt": {
			"type": "object",
			"required": [
				"source",
				"scope",
				"query",
				"row_count",
				"session_count",
				"execution_ms",
				"cost_source",
				"pricing"
			],
			"additionalProperties": false,
			"properties": {
				"source": { "enum": ["query_plane", "agentsview"] },
				"scope": { "type": "string" },
				"query": { "type": "string" },
				"row_count": { "type": "integer", "minimum": 0 },
				"session_count": { "type": "integer", "minimum": 0 },
				"execution_ms": { "type": ["integer", "null"], "minimum": 0 },
				"cost_source": { "enum": ["computed", "reported", "mixed"] },
				"pricing": { "$ref": "#/$defs/pricing" }
			}
		},
		"pricing": {
			"type": "object",
			"required": ["source", "table_version", "digest", "effective_row_count", "models"],
			"additionalProperties": false,
			"properties": {
				"source": { "type": "string" },
				"table_version": { "type": "string" },
				"digest": { "type": "string", "pattern": "^sha256:" },
				"effective_row_count": { "type": "integer", "minimum": 0 },
				"models": { "type": "array", "items": { "$ref": "#/$defs/rate" } }
			}
		},
		"rate": {
			"type": "object",
			"required": [
				"model",
				"matched_pattern",
				"input_per_mtok",
				"output_per_mtok",
				"cache_creation_per_mtok",
				"cache_read_per_mtok"
			],
			"additionalProperties": false,
			"properties": {
				"model": { "type": "string" },
				"matched_pattern": { "type": "string" },
				"input_per_mtok": { "type": "number" },
				"output_per_mtok": { "type": "number" },
				"cache_creation_per_mtok": { "type": "number" },
				"cache_read_per_mtok": { "type": "number" }
			}
		}
	}
}
