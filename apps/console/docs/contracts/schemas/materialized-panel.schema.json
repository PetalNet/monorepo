{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "https://petalcat.dev/schemas/console/materialized-panel.schema.json",
	"title": "Materialized panel",
	"type": "object",
	"required": ["schema_version", "panel", "result", "render"],
	"additionalProperties": true,
	"properties": {
		"schema_version": { "const": 1 },
		"panel": { "$ref": "panel-spec-v2.schema.json" },
		"result": {
			"oneOf": [{ "$ref": "query-result.schema.json" }, { "type": "null" }]
		},
		"render": { "$ref": "render-artifact.schema.json" }
	}
}
