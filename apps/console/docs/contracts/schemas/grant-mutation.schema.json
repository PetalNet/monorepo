{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "https://petalcat.dev/schemas/console/grant-mutation.schema.json",
	"title": "Idempotent grant mutation",
	"type": "object",
	"required": ["schema_version", "id", "action", "subject", "relation", "object"],
	"additionalProperties": false,
	"properties": {
		"schema_version": { "const": 1 },
		"id": { "type": "string", "format": "uuid" },
		"action": { "enum": ["grant", "revoke"] },
		"subject": { "type": "string" },
		"relation": { "enum": ["viewer", "editor", "operator", "owner"] },
		"object": {
			"type": "string",
			"pattern": "^(user:[a-z0-9._-]+|agent:[a-z0-9._-]+|project:[a-z0-9._-]+|fleet|restricted:[a-z0-9._-]+|item:[a-zA-Z0-9_-]{8,128})$"
		},
		"condition": { "type": ["string", "null"], "maxLength": 128 },
		"valid_at": { "type": "string", "format": "date-time" },
		"invalid_at": {
			"type": ["string", "null"],
			"format": "date-time",
			"description": "When non-null, valid_at is required and this must be later."
		}
	}
}
