{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "https://petalcat.dev/schemas/console/assistant-context.schema.json",
	"title": "Selected UI context delivered to the per-user assistant",
	"type": "object",
	"required": ["id", "payload"],
	"additionalProperties": false,
	"properties": {
		"id": { "type": "string", "format": "uuid" },
		"payload": {
			"type": "object",
			"required": ["element_kind", "value"],
			"additionalProperties": false,
			"properties": {
				"element_kind": { "type": "string", "minLength": 1, "maxLength": 100 },
				"field": { "type": "string", "maxLength": 200 },
				"value": true,
				"datum": { "type": "object" },
				"query_ref": { "type": "string", "maxLength": 100 },
				"entity_ref": { "type": "string", "maxLength": 500 }
			}
		}
	}
}
