{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "https://petalcat.dev/schemas/console/dashboard-save.schema.json",
	"title": "Save dashboard / investigation node",
	"type": "object",
	"required": ["schema_version", "id", "title", "panels"],
	"additionalProperties": false,
	"properties": {
		"schema_version": { "const": 1 },
		"id": {
			"type": "string",
			"format": "uuid",
			"description": "Client-minted mutation id; retries by the same principal return the original dashboard, while a changed body is id_reused."
		},
		"title": { "type": "string", "minLength": 1, "maxLength": 200 },
		"scope": { "type": "string" },
		"layout": { "type": "object" },
		"panels": {
			"type": "array",
			"maxItems": 60,
			"items": { "$ref": "panel-spec-v2.schema.json" }
		},
		"branch": {
			"type": "object",
			"additionalProperties": false,
			"properties": {
				"parent_dashboard_id": { "type": ["string", "null"] },
				"parent_question": { "type": ["string", "null"], "maxLength": 2000 },
				"filters": { "type": "object" },
				"selected_mark": {
					"type": ["object", "null"],
					"required": ["element_kind"],
					"additionalProperties": false,
					"properties": {
						"element_kind": { "type": "string" },
						"field": { "type": "string" },
						"value": true,
						"datum": { "type": "object" },
						"query_ref": { "type": "string" },
						"entity_ref": { "type": "string" }
					}
				},
				"assumptions": { "type": "array", "maxItems": 50, "items": { "type": "string" } }
			}
		},
		"time": {
			"type": "object",
			"required": ["from"],
			"additionalProperties": false,
			"properties": {
				"from": { "type": "string" },
				"to": { "type": ["string", "null"] },
				"refresh_s": { "type": ["integer", "null"], "minimum": 1, "maximum": 86400 }
			}
		}
	}
}
