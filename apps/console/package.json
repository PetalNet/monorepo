{
	"name": "@petalnet/console",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "vite build",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"dev": "vite dev",
		"lint": "svelte-kit sync && eslint -c eslint.config.ts src tests vite.config.ts playwright.config.ts --max-warnings=0",
		"migrate": "effectdb migrate up",
		"prepare": "svelte-kit sync",
		"preview": "vite preview",
		"test": "vitest run",
		"test:e2e": "playwright test"
	},
	"dependencies": {
		"@effect/sql-pg": "catalog:",
		"@lucide/svelte": "catalog:prod",
		"@opentelemetry/api": "catalog:",
		"@opentelemetry/auto-instrumentations-node": "catalog:",
		"@opentelemetry/exporter-trace-otlp-proto": "catalog:",
		"@opentelemetry/sdk-node": "catalog:",
		"@petalnet/better-auth-effect-qb-adapter": "workspace:*",
		"@sentry/sveltekit": "catalog:",
		"@sveltejs/kit": "catalog:",
		"better-auth": "catalog:",
		"daisyui": "catalog:prod",
		"effect": "catalog:",
		"import-in-the-middle": "catalog:",
		"svelte": "catalog:prod",
		"svelte-effect-runtime": "catalog:",
		"tailwindcss": "catalog:prod"
	},
	"devDependencies": {
		"@playwright/test": "catalog:dev",
		"@sveltejs/adapter-node": "catalog:dev",
		"@sveltejs/vite-plugin-svelte": "catalog:dev",
		"@tailwindcss/vite": "catalog:dev",
		"@types/node": "catalog:types",
		"effect-db": "catalog:",
		"effect-qb": "catalog:",
		"eslint": "catalog:dev",
		"eslint-plugin-svelte": "catalog:dev",
		"fontless": "catalog:prod",
		"svelte-check": "catalog:dev",
		"svelte-global-typescript": "catalog:",
		"svelte-plugin-composer": "catalog:",
		"typescript": "catalog:dev",
		"typescript-eslint": "catalog:dev",
		"vite": "catalog:dev",
		"vitest": "catalog:dev"
	}
}
