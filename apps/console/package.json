{
	"name": "@petalnet/console",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"scripts": {
		"prebuild": "node scripts/generate-contracts.mjs --check",
		"build": "vite build",
		"check": "node scripts/generate-contracts.mjs --check && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"contracts:check": "node scripts/generate-contracts.mjs --check",
		"contracts:generate": "node scripts/generate-contracts.mjs",
		"dev": "vite dev",
		"lint": "oxlint src scripts --max-warnings=0",
		"prepare": "svelte-kit sync || echo ''",
		"preview": "vite preview",
		"test": "node --test --experimental-strip-types src/**/*.test.ts && vitest run src/routes/caught-failures.contract.spec.ts",
		"test:e2e": "playwright test"
	},
	"dependencies": {
		"@fontsource/geist-mono": "catalog:prod",
		"@fontsource/geist-sans": "catalog:prod",
		"@lucide/svelte": "catalog:prod",
		"@petalnet/types": "workspace:*",
		"@sentry/sveltekit": "catalog:prod",
		"@sveltejs/kit": "catalog:prod",
		"better-auth": "catalog:",
		"daisyui": "catalog:prod",
		"pg": "catalog:",
		"svelte": "catalog:prod",
		"tailwindcss": "catalog:prod",
		"zod": "catalog:prod"
	},
	"devDependencies": {
		"@playwright/test": "catalog:dev",
		"@sveltejs/adapter-node": "catalog:dev",
		"@sveltejs/vite-plugin-svelte": "catalog:dev",
		"@tailwindcss/vite": "catalog:dev",
		"@types/node": "catalog:types",
		"@types/pg": "catalog:",
		"svelte-check": "catalog:dev",
		"typescript": "catalog:dev",
		"vite": "catalog:dev",
		"vitest": "catalog:dev"
	}
}
