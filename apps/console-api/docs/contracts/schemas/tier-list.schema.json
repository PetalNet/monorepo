{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "https://petalcat.dev/schemas/console/tier-list.schema.json",
	"title": "Extensible permission-level catalog",
	"type": "object",
	"required": ["schema_version", "items"],
	"additionalProperties": true,
	"properties": {
		"schema_version": { "const": 1 },
		"items": {
			"type": "array",
			"items": {
				"type": "object",
				"required": ["name", "authentik_group", "description", "default_relations", "propose_only"],
				"additionalProperties": true,
				"properties": {
					"name": { "type": "string", "pattern": "^[a-z][a-z0-9_-]{0,63}$" },
					"authentik_group": { "type": ["string", "null"] },
					"description": { "type": "string" },
					"default_relations": {
						"type": "array",
						"items": { "enum": ["viewer", "editor", "operator", "owner"] }
					},
					"propose_only": { "type": "boolean" }
				}
			}
		}
	}
}
