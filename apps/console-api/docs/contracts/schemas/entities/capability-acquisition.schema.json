{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "https://petalnet.dev/schemas/entities/capability-acquisition.schema.json",
	"title": "Capability acquisition",
	"type": "object",
	"additionalProperties": true,
	"required": [
		"schema_version",
		"capability",
		"kind",
		"version",
		"provider",
		"scope",
		"integrity",
		"artifact",
		"provenance"
	],
	"properties": {
		"schema_version": { "const": 1 },
		"capability": { "type": "string", "minLength": 1, "maxLength": 128 },
		"kind": { "enum": ["skill", "tool"] },
		"version": { "type": "string", "minLength": 1 },
		"provider": { "type": "string", "minLength": 1 },
		"scope": { "type": "string", "minLength": 1 },
		"integrity": {
			"type": "object",
			"additionalProperties": true,
			"required": ["algorithm", "digest"],
			"properties": {
				"algorithm": { "const": "sha256" },
				"digest": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
			}
		},
		"artifact": {
			"type": "object",
			"additionalProperties": true,
			"required": ["media_type", "encoding", "bytes", "data"],
			"properties": {
				"media_type": { "const": "application/vnd.petalnet.capability-bundle+json" },
				"encoding": { "const": "base64" },
				"bytes": { "type": "integer", "minimum": 1, "maximum": 2097152 },
				"data": { "type": "string", "contentEncoding": "base64" }
			}
		},
		"provenance": {
			"type": "object",
			"additionalProperties": true,
			"required": [
				"library_item_id",
				"library_item_version",
				"created_by_agent",
				"responsible_human",
				"source_url",
				"registry_observed_at"
			],
			"properties": {
				"library_item_id": { "type": "string", "minLength": 1 },
				"library_item_version": { "type": "integer", "minimum": 1 },
				"created_by_agent": { "type": ["string", "null"] },
				"responsible_human": { "type": ["string", "null"] },
				"source_url": { "type": ["string", "null"] },
				"registry_observed_at": { "type": "string", "format": "date-time" }
			}
		}
	}
}
