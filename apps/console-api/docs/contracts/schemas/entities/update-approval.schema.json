{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "https://petalcat.dev/schemas/console/entities/update-approval.schema.json",
	"title": "Pending staged update approval (GET /update-approvals)",
	"description": "One active, unapplied approval for collector-grounded packages on a staged-approval host. Filters: required box_id, plus shared limit/cursor/since.",
	"type": "object",
	"properties": {
		"approval_id": { "type": "string", "format": "uuid" },
		"box_id": { "type": "string", "minLength": 1, "maxLength": 256 },
		"packages": {
			"type": "array",
			"minItems": 1,
			"maxItems": 500,
			"uniqueItems": true,
			"items": { "type": "string", "minLength": 1, "maxLength": 256 }
		},
		"approved_by": { "type": "string", "minLength": 1 },
		"approved_at": { "type": "string", "format": "date-time" },
		"revocable": {
			"type": "boolean",
			"description": "Live ledger capability; true only while this collector-backed approval supports reversal."
		},
		"observed_at": { "type": "string", "format": "date-time" }
	},
	"required": [
		"approval_id",
		"box_id",
		"packages",
		"approved_by",
		"approved_at",
		"revocable",
		"observed_at"
	],
	"additionalProperties": false
}
