{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "https://petalcat.dev/schemas/console/cost-comparison-request.schema.json",
	"title": "Cost pairwise comparison request",
	"type": "object",
	"required": ["schema_version", "dimension", "left", "right", "from", "to", "timezone"],
	"additionalProperties": false,
	"properties": {
		"schema_version": { "const": 1 },
		"dimension": { "enum": ["agent", "model", "project"] },
		"left": { "type": "string", "minLength": 1, "maxLength": 256 },
		"right": { "type": "string", "minLength": 1, "maxLength": 256 },
		"from": { "type": "string", "format": "date-time" },
		"to": { "type": "string", "format": "date-time" },
		"timezone": { "type": "string", "minLength": 1, "maxLength": 64 }
	}
}
