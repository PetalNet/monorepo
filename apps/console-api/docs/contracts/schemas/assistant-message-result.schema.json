{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "https://petalcat.dev/schemas/console/assistant-message-result.schema.json",
	"title": "Per-user dashboard assistant response",
	"type": "object",
	"required": ["schema_version", "session_id", "message_id", "content", "tool_results"],
	"additionalProperties": true,
	"properties": {
		"schema_version": { "const": 1 },
		"session_id": { "type": "string" },
		"message_id": { "type": "string" },
		"content": { "type": "string" },
		"tool_results": { "type": "array" }
	}
}
