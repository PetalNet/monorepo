{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://petalcat.dev/schemas/console/panel-spec-v2.schema.json",
  "title": "PanelSpec v2 (render contract)",
  "description": "Citeseer's PanelSpec lineage with the named 2nd-pass extensions: query_ref indirection (replaces inlined SQL; the provenance peek resolves the ref), stat bindings for prose, layout as data, live binding. Charts and investigation-tree state are data — savable, replayable, renderer-agnostic. Type-specific requirements are enforced by the allOf branches: data panels require query_ref; text panels require prose; refusal panels require refusal. Consumers MUST ignore unknown fields.",
  "type": "object",
  "required": ["schema_version", "type", "title"],
  "additionalProperties": true,
  "properties": {
    "schema_version": { "const": 2 },
    "type": { "enum": ["bar", "line", "stat", "table", "pie", "scatter", "gauge", "heatmap", "histogram", "insight", "text", "refusal"] },
    "title": { "type": "string", "maxLength": 200 },
    "description": { "type": ["string", "null"] },
    "query_ref": { "type": ["string", "null"], "description": "Durable ref to the executed query (query-result.query_ref). Replaces citeseer's inlined per-panel sql. Peek ('Show the math.') and re-run resolve this." },
    "encoding": {
      "type": ["object", "null"],
      "additionalProperties": true,
      "properties": {
        "x": { "type": ["string", "null"] },
        "y": { "type": ["string", "null"] },
        "group_by": { "type": ["string", "null"] },
        "columns": { "type": ["array", "null"], "items": { "type": "string" } },
        "value": { "type": ["string", "null"] },
        "unit": { "type": ["string", "null"] },
        "color": { "type": ["string", "null"] },
        "color_palette": { "type": ["array", "null"], "items": { "type": "string" }, "description": "Ordered categorical palette (citeseer effectivePalette lineage; also supplies the forecast secondary color)." },
        "color_map": { "type": ["object", "null"], "additionalProperties": { "type": "string" } }
      }
    },
    "prose": { "type": ["string", "null"], "description": "text panels: markdown with stat bindings {{stat:<query_ref>#<column>[agg]}} — live, proved, drillable inline numbers. Unbound numbers are visibly unproven." },
    "refusal": {
      "type": ["object", "null"],
      "additionalProperties": true,
      "required": ["reason"],
      "properties": {
        "reason": { "type": "string" },
        "suggestions": { "type": "array", "items": { "type": "string" } }
      }
    },
    "summary": { "type": ["string", "null"] },
    "narrative": { "type": ["string", "null"] },
    "confidence": { "enum": ["high", "medium", "low", null] },
    "recommendations": { "type": ["array", "null"], "items": { "type": "string" } },
    "suggestions": { "type": ["array", "null"], "items": { "type": "string" }, "description": "Suggested follow-up investigations on SUCCESSFUL answers (citeseer suggestedInvestigations; refusal panels carry theirs inside refusal.suggestions)." },
    "forecast": {
      "type": ["object", "null"],
      "additionalProperties": true,
      "properties": {
        "strategy": { "enum": ["auto", "linear", "drift", "moving_average", "exp_smoothing", "seasonal_naive"] },
        "horizon": { "type": "integer" },
        "window": { "type": ["integer", "null"] },
        "alpha": { "type": ["number", "null"] },
        "season_length": { "type": ["integer", "null"] },
        "confidence": { "enum": ["high", "medium", "low", null], "description": "citeseer ForecastSpec.confidence (enum). The numeric band width is interval_pct." },
        "interval_pct": { "type": ["number", "null"] }
      }
    },
    "layout": {
      "type": ["object", "null"],
      "additionalProperties": true,
      "properties": {
        "col": { "type": "integer", "minimum": 0, "maximum": 11 },
        "span": { "type": "integer", "minimum": 3, "maximum": 12 },
        "row": { "type": "integer", "minimum": 0 },
        "height": { "type": ["integer", "null"] },
        "group": { "type": ["string", "null"] },
        "highlight": { "type": "boolean", "default": false },
        "locked": { "type": "boolean", "default": false }
      }
    },
    "live": {
      "type": ["object", "null"],
      "additionalProperties": true,
      "properties": {
        "pattern": { "type": "string" },
        "cadence_s": { "type": ["number", "null"] }
      }
    }
  },
  "allOf": [
    { "if": { "properties": { "type": { "enum": ["bar", "line", "stat", "table", "pie", "scatter", "gauge", "heatmap", "histogram", "insight"] } } }, "then": { "required": ["query_ref"], "properties": { "query_ref": { "type": "string" } } } },
    { "if": { "properties": { "type": { "const": "text" } } }, "then": { "required": ["prose"], "properties": { "prose": { "type": "string" } } } },
    { "if": { "properties": { "type": { "const": "refusal" } } }, "then": { "required": ["refusal"], "properties": { "refusal": { "type": "object" } } } }
  ]
}
