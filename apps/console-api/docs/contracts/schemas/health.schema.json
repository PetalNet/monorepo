{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://petalcat.dev/schemas/console/health.schema.json",
  "title": "GET /api/v1/health",
  "description": "Unauthenticated liveness surface for systemd watchdog + Traefik gate + the Mindy Line health derivation. Consumers MUST ignore unknown fields.",
  "type": "object",
  "required": ["lake", "seq_head", "bridges"],
  "additionalProperties": true,
  "properties": {
    "lake": { "enum": ["ok", "degraded", "down"] },
    "seq_head": { "type": "integer" },
    "bridges": {
      "type": "array",
      "items": { "type": "object", "required": ["source", "last_ingest_at", "lag_s"], "additionalProperties": true, "properties": { "source": { "type": "string" }, "last_ingest_at": { "type": ["string", "null"], "format": "date-time" }, "lag_s": { "type": ["number", "null"] } } }
    },
    "ws_clients": { "type": "integer" },
    "matrix_sync_ok_epoch": { "type": ["integer", "null"], "description": "console-api's own Matrix delivery-path sync health (0/null = never)." }
  }
}
