{
  "$comment": "Console command-plane op catalog (P0). One entry per named op. The frontend renders ActionRows from THIS file; a UI button without an entry here is a defect (no op -> no button). args use informal type notation, tightened to full JSON Schema per-phase as each executor path is built. lane = required capability lane. executor = whose liveness gates availability. emits = audit/effect emission types. lineage = today's as-built shape the op formalizes. phase = when the real path lands (contract is stable from P0).",
  "schema_version": 1,
  "ops": [
    { "op": "attention.ack", "args": { "id": "string" }, "lane": "viewer", "executor": "console-api", "effect": "marks item claimed-by caller; dims + sorts below new", "emits": ["attention.acked"], "phase": 1 },
    { "op": "attention.snooze", "args": { "id": "string", "duration_s": "int=3600" }, "lane": "viewer", "executor": "console-api", "effect": "auto-expiring snooze, visibly listed", "emits": ["attention.snoozed"], "undo": true, "phase": 1 },
    { "op": "attention.resolve", "args": { "id": "string" }, "lane": "viewer", "executor": "console-api", "effect": "channel-agnostic resolution; clears the one shared state", "emits": ["attention.resolved"], "phase": 1 },

    { "op": "task.get_ready", "args": { "capability": "string?" }, "lane": "viewer", "executor": "tracker", "effect": "read: ready queue ordered by up_next/rank/priority", "emits": [], "lineage": "tracker MCP get_ready", "phase": 1 },
    { "op": "task.up_next", "args": { "id": "int", "position": "int?" }, "lane": "operator", "executor": "tracker", "effect": "pin into the up-next lane", "emits": ["task.transitioned"], "lineage": "tracker MCP up_next", "phase": 1 },
    { "op": "task.claim", "args": { "id": "int?", "capability": "string?" }, "lane": "operator", "executor": "tracker", "effect": "atomic CAS todo->doing + lease + fence++; two claimers never both win", "emits": ["task.claimed"], "lineage": "tracker claimNext / queue-lease", "phase": 1 },
    { "op": "task.update", "args": { "id": "int", "patch": "object" }, "lane": "operator", "executor": "tracker", "effect": "status/priority/blockers/verification transitions; store guards illegal transitions; only lease holder reports review|blocked|done", "emits": ["task.transitioned"], "lineage": "tracker updateTask", "phase": 1 },
    { "op": "task.close", "args": { "id": "int", "status": "done|dropped" }, "lane": "operator", "executor": "tracker", "effect": "close with reason (why-ledger)", "emits": ["task.closed"], "requires_reason": true, "lineage": "tracker closeTask", "phase": 1 },
    { "op": "task.dispatch", "args": { "task_id": "int", "recipient": "string?", "body": "string", "priority": "0-3?", "capability": "string?" }, "lane": "operator", "executor": "dispatcher", "effect": "files/loads tracker task, posts task-card, interrupt policy enforced dispatcher-side", "emits": ["card.posted"], "lineage": "dispatcher dispatch()", "phase": 1 },

    { "op": "agent.start", "args": { "handle": "string" }, "lane": "operator", "executor": "manager", "effect": "start the supervised session", "emits": ["agent.lifecycle"], "lineage": "Matrix !start", "phase": 1 },
    { "op": "agent.stop", "args": { "handle": "string" }, "lane": "operator", "executor": "manager", "effect": "stop the supervised session", "emits": ["agent.lifecycle"], "lineage": "Matrix !stop", "phase": 1 },
    { "op": "agent.restart", "args": { "handle": "string" }, "lane": "operator", "executor": "manager", "effect": "restart; allowed on stale target state (recovery gates on manager liveness, confirm notes staleness)", "emits": ["agent.lifecycle"], "lineage": "Matrix !restart", "phase": 1 },
    { "op": "agent.kill_session", "args": { "handle": "string" }, "lane": "admin", "executor": "manager", "effect": "mint a fresh session id — truly new conversation", "emits": ["agent.lifecycle"], "destructive": true, "confirm": "typed-name", "lineage": "Matrix !kill session", "phase": 1 },
    { "op": "agent.autonomy", "args": { "handle": "string", "autonomy": "auto|ask|readonly|paused" }, "lane": "operator", "executor": "tracker", "effect": "set roster autonomy", "emits": ["agent.autonomy_changed"], "lineage": "tasks.db agents.autonomy", "phase": 1 },

    { "op": "governance.action", "args": { "handle": "string", "action": "pause|throttle|downgrade|restore", "delay_ms": "int?", "to": "haiku|sonnet|opus?" }, "lane": "operator", "executor": "control-plane", "effect": "manual governance override; edge-triggered like autonomous actions", "emits": ["governance.action"], "lineage": "governance.action spool envelope", "phase": 1 },
    { "op": "governance.tier", "args": { "handle": "string", "tier": "haiku|sonnet|opus" }, "lane": "operator", "executor": "control-plane", "effect": "pin model tier (manager applies via model_override_path)", "emits": ["governance.action"], "lineage": "model override file", "phase": 1 },
    { "op": "fleet.mode", "args": { "mode": "parallel|sequential" }, "lane": "operator", "executor": "control-plane", "effect": "fleet-wide mode; cascade auto-engages, this is the manual path", "emits": ["fleet.mode"], "lineage": "fleet.mode broadcast envelope", "phase": 1 },
    { "op": "channel.reclaim", "args": { "handle": "string" }, "lane": "admin", "executor": "manager", "effect": "NEW: resolve channel_lock lockout — stand down the squatter, re-acquire single-owner lock (closes the lockout-has-no-release gap)", "emits": ["channel.lock_changed"], "phase": 1 },

    { "op": "signal.snooze", "args": { "scope_pattern": "string", "duration_s": "int=3600" }, "lane": "viewer", "executor": "console-api", "effect": "timed mute (Quiet 1h), auto-expires, visibly listed; storm auto-mute uses this attributed to the bus", "emits": ["signal.snoozed"], "undo": true, "phase": 1 },
    { "op": "subscription.set", "args": { "pattern": "string", "tier": "feed|digest|interrupt", "loud": "bool?", "note": "string?", "owner": "string?" }, "lane": "viewer(own)/operator(others)", "executor": "console-api", "effect": "upsert standing subscription", "emits": ["subscription.changed"], "phase": 1 },
    { "op": "subscription.remove", "args": { "pattern": "string", "owner": "string?" }, "lane": "viewer(own)/operator(others)", "executor": "console-api", "effect": "remove standing subscription", "emits": ["subscription.changed"], "phase": 1 },
    { "op": "card.repost", "args": { "card_id": "string" }, "lane": "operator", "executor": "dispatcher", "effect": "dead-letter triage: repost to the board (fresh fence)", "emits": ["card.posted"], "lineage": "board.post", "phase": 1 },
    { "op": "card.park", "args": { "card_id": "string" }, "lane": "operator", "executor": "dispatcher", "effect": "park until capacity/wake", "emits": ["card.parked"], "lineage": "board.park", "phase": 1 },

    { "op": "stats.query", "args": { "request": "query-request" }, "lane": "viewer", "executor": "console-api", "effect": "read as-user; returns query_ref", "emits": [], "phase": 1 },
    { "op": "viz.render", "args": { "panel": "panel-spec-v2" }, "lane": "viewer", "executor": "console-api", "effect": "validate + register a panel spec (render is client-side; this pins provenance)", "emits": [], "phase": 2 },
    { "op": "text.surface", "args": { "prose": "string", "bindings": "stat-binding[]" }, "lane": "viewer", "executor": "console-api", "effect": "text panel with live proved inline stats", "emits": [], "phase": 2 },
    { "op": "window.arrange", "args": { "dashboard_id": "string", "ops": "layout-op[]" }, "lane": "viewer", "executor": "console-api", "effect": "layout mutations as data (place/size/group/highlight/clear/pin)", "emits": [], "phase": 2 },
    { "op": "dashboard.save", "args": { "title": "string", "layout": "object", "panels": "panel-spec-v2[]" }, "lane": "viewer", "executor": "library", "effect": "dashboard = Library item (kind artifact)", "emits": ["library.item.added"], "phase": 1 },
    { "op": "dashboard.load", "args": { "id": "string" }, "lane": "viewer", "executor": "library", "effect": "read; shared dashboards re-run queries AS the viewer (scope refusal is per-panel)", "emits": [], "phase": 1 },
    { "op": "dashboard.set_home", "args": { "id": "string" }, "lane": "viewer", "executor": "library", "effect": "pin as the per-user home", "emits": [], "phase": 1 },
    { "op": "dashboard.pin", "args": { "panel": "panel-spec-v2" }, "lane": "viewer", "executor": "library", "effect": "add a panel to the home dashboard", "emits": [], "phase": 1 },
    { "op": "context.receive", "args": { "payload": "right-click-context" }, "lane": "viewer", "executor": "console-api", "effect": "clicked context -> most recent chat message of the caller's assistant session", "emits": [], "phase": 5 },

    { "op": "kb.search", "args": { "q": "string", "kinds": "string[]?", "limit": "int?" }, "lane": "viewer", "executor": "library", "effect": "hybrid BM25+dense+RRF, scope-filtered below the ranker, why-matched returned", "emits": [], "phase": 2 },
    { "op": "research", "args": { "query": "string" }, "lane": "viewer", "executor": "library", "effect": "sole-egress research: check-before-web, write-back via consolidation gate", "emits": ["library.research"], "phase": 2 },
    { "op": "library.item.create", "args": { "item": "library-item" }, "lane": "operator", "executor": "library", "effect": "create item (scope-checked)", "emits": ["library.item.added"], "phase": 2 },
    { "op": "library.item.update", "args": { "id": "string", "patch": "object" }, "lane": "editor", "executor": "library", "effect": "update; prose merges CRDT; status via MV-Register (CONFLICT surfaces, never silent LWW)", "emits": ["library.item.changed"], "phase": 2 },
    { "op": "library.link.add", "args": { "from_id": "string", "to_id": "string", "rel_type": "belongs-to|supersedes|derived-from|duplicate-of|references", "reason": "string?" }, "lane": "editor", "executor": "library", "effect": "grow-only typed link", "emits": ["library.link.added"], "phase": 2 },
    { "op": "library.hold", "args": { "item_id": "string", "for_user": "string", "reason": "string?" }, "lane": "operator", "executor": "library", "effect": "held-shelf: hold an item aside for a user", "emits": ["library.held"], "phase": 2 },
    { "op": "curation.propose", "args": { "type": "weed|merge|dedup|retire|follow-up", "item_id": "string", "reason": "string" }, "lane": "operator", "executor": "library", "effect": "reviewable curation proposal with blast radius", "emits": ["curation.proposed"], "phase": 2 },
    { "op": "curation.approve", "args": { "proposal_id": "string" }, "lane": "owner", "executor": "library", "effect": "apply proposal (human-gated)", "emits": ["curation.applied"], "phase": 2 },
    { "op": "curation.reject", "args": { "proposal_id": "string" }, "lane": "owner", "executor": "library", "effect": "reject with note", "emits": ["curation.rejected"], "requires_reason": true, "phase": 2 },
    { "op": "item.weed", "args": { "id": "string" }, "lane": "operator", "executor": "library", "effect": "invalidate (reversible)", "emits": ["library.item.changed"], "undo": true, "requires_reason": true, "phase": 2 },
    { "op": "item.merge", "args": { "id": "string", "into_id": "string" }, "lane": "operator", "executor": "library", "effect": "forward supersede, idempotent", "emits": ["library.item.changed"], "phase": 2 },
    { "op": "item.delete", "args": { "id": "string" }, "lane": "owner", "executor": "library", "effect": "rare, human-gated; never offered to agents", "emits": ["library.item.deleted"], "destructive": true, "confirm": "typed-name", "requires_reason": true, "phase": 2 },
    { "op": "promotion.request", "args": { "id": "string" }, "lane": "viewer", "executor": "library", "effect": "personal-draft -> verified-shared request", "emits": ["promotion.requested"], "phase": 2 },
    { "op": "promotion.approve", "args": { "request_id": "string" }, "lane": "owner", "executor": "library", "effect": "approve promotion", "emits": ["promotion.approved"], "phase": 2 },

    { "op": "service.restart", "args": { "host": "string", "service": "string" }, "lane": "operator", "executor": "box-agent", "effect": "restart a container/service on the host", "emits": ["service.lifecycle"], "phase": 1 },
    { "op": "service.stop", "args": { "host": "string", "service": "string" }, "lane": "operator", "executor": "box-agent", "effect": "stop (destructive confirm)", "emits": ["service.lifecycle"], "destructive": true, "phase": 1 },
    { "op": "service.logs", "args": { "host": "string", "service": "string", "lines": "int?" }, "lane": "operator", "executor": "box-agent", "effect": "log tail stream into the drawer", "emits": [], "phase": 1 },
    { "op": "host.probe", "args": { "target": "string" }, "lane": "operator", "executor": "probe-runner", "effect": "re-check availability now", "emits": ["probe.result"], "phase": 2 },
    { "op": "host.reboot", "args": { "box_id": "string" }, "lane": "admin", "executor": "box-agent", "effect": "reboot the box", "emits": ["host.lifecycle"], "destructive": true, "confirm": "typed-name", "phase": 1 },

    { "op": "updates.check", "args": { "box_id": "string" }, "lane": "operator", "executor": "box-agent", "effect": "collector re-check now", "emits": ["box.update_status_changed"], "phase": 1 },
    { "op": "updates.approve", "args": { "box_id": "string", "packages": "string[]?" }, "lane": "operator", "executor": "console-api", "effect": "staged-approval: record approval; apply is separate", "emits": ["updates.approved"], "phase": 1 },
    { "op": "updates.apply", "args": { "box_id": "string" }, "lane": "operator", "executor": "box-agent", "effect": "apply approved updates; availability = apply_mode x agent_vs_agentless x executor liveness (agentless boxes: op never exists -> caption, not disabled)", "emits": ["box.update_status_changed"], "phase": 1 },

    { "op": "edge.enroll.approve", "args": { "pubkey_fp": "string", "handle": "string" }, "lane": "admin", "executor": "edge+control-plane", "effect": "Key Ceremony approve: bind pubkey->handle, mint enrollment via TokenAuthority (closes the enrollment gap)", "emits": ["edge.enrolled"], "phase": 1 },
    { "op": "edge.enroll.deny", "args": { "pubkey_fp": "string" }, "lane": "admin", "executor": "edge", "effect": "deny pending enrollment", "emits": ["edge.enroll_denied"], "requires_reason": true, "phase": 1 },
    { "op": "edge.key.revoke", "args": { "pubkey_fp": "string" }, "lane": "admin", "executor": "edge+control-plane", "effect": "revoke enrolled key; sessions drop", "emits": ["edge.key_revoked"], "destructive": true, "confirm": "typed-name", "requires_reason": true, "phase": 1 },
    { "op": "doorman.session.drop", "args": { "session_id": "string" }, "lane": "admin", "executor": "edge", "effect": "drop a live session", "emits": ["doorman.session.closed"], "phase": 1 },
    { "op": "doorman.redial", "args": { "handle": "string" }, "lane": "admin", "executor": "manager", "effect": "ask the agent's manager to redial; rides the Matrix floor when the tunnel is down", "emits": ["doorman.redial"], "phase": 1 },

    { "op": "term.watch", "args": { "host": "string", "tmux_session": "string", "pane_id": "string", "scrollback_lines": "int?" }, "lane": "term_admin", "executor": "pty", "effect": "open read stream; audit line commits BEFORE first frame or the stream never opens", "emits": ["term.session"], "agents_excluded": true, "phase": 1 },
    { "op": "term.attach", "args": { "stream_id": "string" }, "lane": "term_admin", "executor": "pty", "effect": "escalate to write mode (entry-by-consent)", "emits": ["term.session"], "agents_excluded": true, "phase": 1 },
    { "op": "term.input", "args": { "stream_id": "string", "seq": "int", "data_b64": "string" }, "lane": "term_admin", "executor": "pty", "effect": "keystrokes; input logged as sealed blobs (opening is itself audited)", "emits": [], "agents_excluded": true, "phase": 1 },
    { "op": "term.resize", "args": { "stream_id": "string", "cols": "int", "rows": "int" }, "lane": "term_admin", "executor": "pty", "effect": "resize", "emits": [], "agents_excluded": true, "phase": 1 },
    { "op": "term.scrollback", "args": { "stream_id": "string", "lines": "int" }, "lane": "term_admin", "executor": "pty", "effect": "fetch scrollback", "emits": [], "agents_excluded": true, "phase": 1 },
    { "op": "term.detach", "args": { "stream_id": "string" }, "lane": "term_admin", "executor": "pty", "effect": "close stream", "emits": ["term.session"], "agents_excluded": true, "phase": 1 },

    { "op": "delivery.test", "args": {}, "lane": "viewer(own)", "executor": "console-api", "effect": "send vetted test body via Matrix; result renders the receipt honestly", "emits": ["delivery.receipt"], "phase": 1 },
    { "op": "delivery.set_target", "args": { "channel": "matrix", "target": "string" }, "lane": "viewer(own)", "executor": "console-api", "effect": "set + auto-test; verified flips only on a delivered receipt", "emits": ["delivery.receipt"], "phase": 1 },
    { "op": "delivery.cocoon", "args": { "until": "date-time" }, "lane": "viewer(own)", "executor": "console-api", "effect": "quiet hours; severity p0 + interrupt_policy safety ALWAYS pass (enforced at dispatch)", "emits": ["delivery.cocoon_changed"], "undo": true, "phase": 1 }
  ]
}
